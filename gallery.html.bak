<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IZUNAX — Галерея</title>
  <link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#ff3366">
<script>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js');
  }
</script>
      <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap');
        :root { --bg:#0a0a0f;--bg2:#0f0f1a;--red:#ff3366;--red-dim:rgba(255,51,102,0.3);--purple:#8b00ff;--text:#e8e0f0;--text-dim:#888;--text-faint:#555;--border:rgba(255,255,255,0.06);--card:rgba(15,15,20,0.9);--input:#1a1a1a; }
        .theme-light { --bg:#f5f5f5;--bg2:#fff;--text:#1a1a1a;--text-dim:#666;--text-faint:#999;--border:rgba(0,0,0,0.08);--card:rgba(255,255,255,0.95);--input:#f0f0f0; }
        .theme-purple { --bg:#0d001a;--bg2:#15002e;--red:#bb00ff;--red-dim:rgba(187,0,255,0.3);--text:#e8d0ff;--text-dim:#9a7abf;--text-faint:#5a3a7f;--border:rgba(187,0,255,0.1);--card:rgba(21,0,46,0.95);--input:#1a0030; }
        .theme-green { --bg:#001a0a;--bg2:#002e15;--red:#00ff66;--red-dim:rgba(0,255,102,0.3);--text:#d0ffe0;--text-dim:#7abf9a;--text-faint:#3a7f5a;--border:rgba(0,255,102,0.1);--card:rgba(0,46,21,0.95);--input:#00301a; }
        .theme-gold { --bg:#1a1500;--bg2:#2e2500;--red:#ffd700;--red-dim:rgba(255,215,0,0.3);--text:#ffe8a0;--text-dim:#bfa060;--text-faint:#7f6a30;--border:rgba(255,215,0,0.1);--card:rgba(46,37,0,0.95);--input:#302800; }
        .theme-blue { --bg:#000a1a;--bg2:#00152e;--red:#0099ff;--red-dim:rgba(0,153,255,0.3);--text:#d0e8ff;--text-dim:#7ab0bf;--text-faint:#3a607f;--border:rgba(0,153,255,0.1);--card:rgba(0,21,46,0.95);--input:#001830; }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:var(--bg); color:var(--text); font-family:'Rajdhani',sans-serif; min-height:100vh; transition:all 0.3s; }
        .header { position:fixed; top:0; left:0; right:0; z-index:100; background:rgba(10,10,15,0.9); backdrop-filter:blur(12px); border-bottom:1px solid var(--border); }
        .header-inner { max-width:1200px; margin:0 auto; padding:0 20px; height:60px; display:flex; align-items:center; gap:12px; }
        .logo { text-decoration:none; display:flex; align-items:baseline; gap:4px; }
        .logo-ix { font-family:'Cinzel',serif; font-size:1.3rem; font-weight:900; color:var(--red); }
        .logo-full { font-family:'Cinzel',serif; font-size:0.9rem; font-weight:700; color:var(--text-dim); letter-spacing:2px; }
        .nav { margin-left:auto; display:flex; align-items:center; gap:6px; }
        .nav a { color:var(--text-dim); text-decoration:none; font-weight:600; letter-spacing:1px; padding:6px 10px; font-size:13px; text-transform:uppercase; }
        .nav a:hover { color:var(--text); }
        .more-menu { position:relative; display:inline-block; }
        .more-btn { background:none; border:none; color:var(--text-dim); font-size:20px; cursor:pointer; padding:6px 10px; }
        .more-dropdown { position:absolute; top:38px; right:0; background:var(--card); border:1px solid var(--red-dim); border-radius:12px; min-width:160px; z-index:150; display:none; }
        .more-dropdown.active { display:block; }
        .more-dropdown a { display:block; padding:10px 14px; color:var(--text-dim); text-decoration:none; font-size:12px; border-bottom:1px solid var(--border); }
        .main { max-width:1200px; margin:80px auto 40px; padding:0 20px; }
        .search-wrap { display:flex; gap:10px; margin-bottom:20px; }
        .search-input { flex:1; padding:12px; background:var(--input); border:1px solid var(--border); border-radius:10px; color:var(--text); font-family:'Rajdhani',sans-serif; }
        .btn { padding:12px 20px; border-radius:10px; font-weight:700; cursor:pointer; font-family:'Rajdhani',sans-serif; border:none; font-size:13px; text-transform:uppercase; }
        .btn-primary { background:linear-gradient(90deg,var(--purple),var(--red)); color:#fff; }
        .art-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:16px; }
        .art-card { background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:hidden; cursor:pointer; transition:all 0.2s; }
        .art-card:hover { transform:translateY(-4px); border-color:var(--red-dim); }
        .art-card img { width:100%; aspect-ratio:1; object-fit:cover; }
        .art-card-body { padding:10px 14px; }
        .art-card-title { font-weight:600; font-size:14px; }
        .art-card-author { color:var(--red); font-size:12px; cursor:pointer; }
        .art-card-meta { display:flex; justify-content:space-between; color:var(--text-faint); font-size:11px; margin-top:4px; }
        .fab { position:fixed; bottom:30px; right:30px; width:56px; height:56px; background:linear-gradient(135deg,var(--purple),var(--red)); border:none; border-radius:50%; color:#fff; font-size:26px; cursor:pointer; z-index:50; display:none; }
        .modal { position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:200; display:flex; align-items:center; justify-content:center; padding:20px; }
        .modal-content { background:var(--card); border:1px solid var(--red-dim); border-radius:16px; padding:20px; max-width:500px; width:100%; max-height:90vh; overflow-y:auto; }
        @media(max-width:600px){ .art-grid{grid-template-columns:repeat(2,1fr);} .nav a{font-size:10px;padding:4px 5px;} }
    </style>
</head>
<body>
<header class="header"><div class="header-inner">
    <a href="index.html" class="logo"><span class="logo-ix">IX</span><span class="logo-full">IZUNAX</span></a>
    <nav class="nav">
        <a href="gallery.html" style="color:var(--red);">Галерея</a>
        <a href="chat.html">💬Чат</a>
        <a href="messages.html">✉ЛС</a>
        <a href="bookmarks.html">⭐</a>
        <a href="profile.html" id="navProfile" style="display:none">Профіль</a>
        <span class="more-menu"><button class="more-btn" onclick="toggleMore()">⋯</button>
            <div class="more-dropdown" id="moreDropdown">
                <a href="settings.html">⚙️Налаштування</a>
                <a href="secret-admin.html">⚡Admin</a>
                <a href="#" onclick="doLogout()" style="color:#ff4444;">🚪Вийти</a>
            </div>
        </span>
        <a href="login.html" id="navLogin">Увійти</a>
    </nav>
</div></header>
<main class="main">
    <div class="search-wrap">
        <input type="text" class="search-input" id="searchInput" placeholder="🔍 Пошук...">
        <button class="btn btn-primary" onclick="filterArts()">Знайти</button>
        <button class="btn" onclick="document.getElementById('searchInput').value='';filterArts();" style="background:transparent;border:1px solid var(--border);color:var(--text-dim);">Скинути</button>
    </div>
    <div class="art-grid" id="artGrid">Завантаження...</div>
</main>
<button class="fab" id="fabBtn" onclick="uploadArt()">+</button>
<script type="module">
import { auth, db, collection, getDocs, addDoc, query, orderBy, limit, doc, updateDoc, deleteDoc, increment, arrayUnion, arrayRemove, serverTimestamp, onAuthStateChanged } from "./firebase-auth.js";
let currentUser=null,allArts=[],bookmarks=[];
const t=localStorage.getItem('izunax_theme')||'dark'; document.body.classList.toggle('theme-light',t==='light'); document.body.classList.toggle('theme-purple',t==='purple'); document.body.classList.toggle('theme-green',t==='green'); document.body.classList.toggle('theme-gold',t==='gold'); document.body.classList.toggle('theme-blue',t==='blue');
window.doLogout=()=>{auth.signOut();window.location.href='login.html';};
window.toggleMore=()=>document.getElementById('moreDropdown').classList.toggle('active');
document.addEventListener('click',e=>{if(!e.target.closest('.more-menu'))document.getElementById('moreDropdown').classList.remove('active');});
onAuthStateChanged(auth,async u=>{
    if(u){currentUser=u;document.getElementById('navLogin').style.display='none';document.getElementById('navProfile').style.display='';document.getElementById('fabBtn').style.display='flex';
        const s=await getDoc(doc(db,'users',u.uid)); bookmarks=s.exists()?(s.data().bookmarks||[]):[];}
    else document.getElementById('fabBtn').style.display='none';
    loadArts();
});
async function loadArts(){
    const g=document.getElementById('artGrid');
    try{const s=await getDocs(query(collection(db,'artworks'),orderBy('createdAt','desc'),limit(50)));
        allArts=[]; s.forEach(d=>allArts.push({id:d.id,...d.data()}));
        filterArts();}
    catch(e){g.innerHTML=`<p style="color:var(--red);">${e.message}</p>`;}
}
window.filterArts=()=>{
    const q=document.getElementById('searchInput').value.toLowerCase();
    const f=q?allArts.filter(a=>(a.title||'').toLowerCase().includes(q)||(a.author||'').toLowerCase().includes(q)):allArts;
    const g=document.getElementById('artGrid');
    if(!f.length){g.innerHTML='<p style="grid-column:1/-1;text-align:center;color:var(--text-faint);">Нічого не знайдено</p>';return;}
    g.innerHTML=f.map(a=>{
        const s=bookmarks.includes(a.id);
        return `<div class="art-card" onclick="viewArt('${a.id}')">
            <img src="${a.image}" alt="${a.title}" loading="lazy">
            <div class="art-card-body">
                <div class="art-card-title">${a.title}</div>
                <span class="art-card-author" onclick="event.stopPropagation();openUser('${a.authorUid}')">@${a.author}</span>
                <div class="art-card-meta"><span>♥${a.likes||0}</span><span onclick="event.stopPropagation();toggleBookmark('${a.id}',${!s})" style="cursor:pointer;">${s?'⭐':'☆'}</span></div>
            </div></div>`;
    }).join('');
};
window.viewArt=id=>{
    const a=allArts.find(x=>x.id===id); if(!a)return;
    const m=document.createElement('div'); m.className='modal';
    m.innerHTML=`<div class="modal-content">
        <img src="${a.image}" style="width:100%;max-height:300px;object-fit:contain;border-radius:8px;">
        <h3 style="font-family:'Cinzel',serif;">${a.title}</h3><p style="color:var(--text-dim);">@${a.author}</p>
        <p>${a.desc||''}</p>
        <button onclick="likeArt('${a.id}')" class="btn btn-primary" style="margin:5px;">♥ ${a.likes||0}</button>
        ${currentUser&&currentUser.uid===a.authorUid?`<button onclick="deleteArt('${a.id}')" class="btn" style="background:#ff4444;color:#fff;margin:5px;">🗑Видалити</button>`:''}
        <div style="margin-top:10px;"><b>Коментарі:</b><div id="comments_${a.id}">—</div>
        <input id="cinp_${a.id}" placeholder="Коментар..." style="width:100%;padding:8px;margin-top:5px;background:var(--input);border:1px solid var(--border);color:var(--text);"><button onclick="addComment('${a.id}')" class="btn btn-primary" style="margin-top:5px;">➤</button></div>
        <button onclick="this.closest('.modal').remove()" style="margin-top:10px;background:var(--bg3);border:none;color:var(--text-dim);padding:8px 20px;border-radius:8px;cursor:pointer;">Закрити</button>
    </div>`;
    document.body.appendChild(m); m.addEventListener('click',e=>{if(e.target===m)m.remove();});
    loadComments(a.id);
};
window.likeArt = async (id) => {
    const art = allArts.find(x => x.id === id);
    if (!art) return;
    
    // Оновлюємо лайки арта
    await updateDoc(doc(db, 'artworks', id), { likes: increment(1) });
    
    // Оновлюємо локально
    art.likes = (art.likes || 0) + 1;
    
    // Оновлюємо лічильник лайків у автора
    if (art.authorUid) {
        const authorRef = doc(db, 'users', art.authorUid);
        await updateDoc(authorRef, { likes: increment(1) });
    }
    
    // Додаємо сповіщення
    if (currentUser && art.authorUid && art.authorUid !== currentUser.uid) {
        await addDoc(collection(db, 'notifications'), {
            forUid: art.authorUid,
            fromUid: currentUser.uid,
            fromName: currentUser.displayName || 'Хтось',
            type: 'like',
            read: false,
            createdAt: serverTimestamp()
        });
    }
    
    document.querySelector('.modal')?.remove();
    loadArts();
};
window.deleteArt=async id=>{if(!confirm('Видалити?'))return;await deleteDoc(doc(db,'artworks',id));allArts=allArts.filter(a=>a.id!==id);document.querySelector('.modal')?.remove();loadArts();};
async function loadComments(artId){
    const c=document.getElementById(`comments_${artId}`); if(!c)return;
    const s=await getDocs(collection(db,`artworks/${artId}/comments`));
    const cs=[]; s.forEach(d=>cs.push(d.data()));
    c.innerHTML=cs.length?cs.map(x=>`<div style="font-size:12px;"><strong style="color:var(--red);">${x.authorName}:</strong> ${x.text}</div>`).join(''):'<span style="color:var(--text-faint);">—</span>';
}
window.addComment=async artId=>{
    const inp=document.getElementById(`cinp_${artId}`); const t=inp.value.trim(); if(!t)return;
    await addDoc(collection(db,`artworks/${artId}/comments`),{authorName:currentUser?.displayName||'Анонім',text:t,createdAt:serverTimestamp()});
    inp.value=''; loadComments(artId);
};
window.toggleBookmark=async(id,save)=>{if(!currentUser)return;const r=doc(db,'users',currentUser.uid);await updateDoc(r,save?{bookmarks:arrayUnion(id)}:{bookmarks:arrayRemove(id)});bookmarks=save?[...bookmarks,id]:bookmarks.filter(x=>x!==id);loadArts();};
window.openUser=async uid=>{
    const m=document.createElement('div');m.className='modal';m.innerHTML='<div class="modal-content"><p>Loading...</p></div>';document.body.appendChild(m);
    const s=await getDoc(doc(db,'users',uid));if(!s.exists()){m.querySelector('.modal-content').innerHTML='<p>Not found</p>';return;}
    const u=s.data(); m.querySelector('.modal-content').innerHTML=`<img src="${u.avatar||'https://i.ibb.co/0jZqY7Z/default-avatar.png'}" style="width:80px;height:80px;border-radius:50%;border:3px solid var(--red);"><h3>${u.name||'Artist'}${u.isVerified?'✓':''}</h3><p>${u.bio||'—'}</p><p>🎨${u.artworks||0}·♥${u.likes||0}</p><button onclick="location.href='messages.html?uid=${uid}'" style="background:linear-gradient(90deg,#8b00ff,#ff1432);color:#fff;border:none;padding:8px 16px;border-radius:8px;cursor:pointer;">💬Написати</button> <button onclick="this.closest('.modal').remove()" style="background:var(--bg3);border:none;color:var(--text-dim);padding:8px 16px;border-radius:8px;cursor:pointer;">Закрити</button>`;
    m.addEventListener('click',e=>{if(e.target===m)m.remove();});
};
window.uploadArt=()=>{
    if(!currentUser)return alert('Увійди!'); const i=document.createElement('input');i.type='file';i.accept='image/*';
    i.onchange=e=>{const f=e.target.files[0];if(!f||f.size>5*1024*1024)return alert('Max 5MB');const r=new FileReader();r.onload=async ev=>{const t=prompt('Назва:');if(!t)return;await addDoc(collection(db,'artworks'),{title:t,image:ev.target.result,author:currentUser.displayName||'Artist',authorUid:currentUser.uid,desc:'',likes:0,createdAt:serverTimestamp()});loadArts();};r.readAsDataURL(f);};i.click();
};
</script>
</body>
</html>