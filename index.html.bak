<!DOCTYPE html>
<html lang="uk">
<head>
<link rel="stylesheet" href="effects.css">
<script src="lang.js"></script>
<script src="particles.js" defer></script>

<!-- SEO / Open Graph -->
<meta property="og:title" content="IZUNAX — Anime Art Platform">
<meta property="og:description" content="Місце для аніме-артів, скетчів і всього з чорнил">
<meta property="og:image" content="https://i.ibb.co/0jZqY7Z/default-avatar.png">
<meta property="og:url" content="https://project-z3cuy.vercel.app">
<meta name="twitter:card" content="summary_large_image">

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IZUNAX — art platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
   <link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#ff3366">
<script>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js');
  }
</script>
     <style>
        :root {
            --bg: #0a0a0f; --bg2: #0f0f1a; --bg3: #141428;
            --red: #ff3366; --red-dim: rgba(255,51,102,0.3);
            --purple: #8b00ff; --text: #e8e0f0;
            --text-dim: #888; --text-faint: #555;
            --border: rgba(255,255,255,0.06);
            --card: rgba(15,15,20,0.9);
            --input: #1a1a1a;
        }
        .theme-light { --bg:#f5f5f5;--bg2:#fff;--bg3:#e8e8e8;--text:#1a1a1a;--text-dim:#666;--text-faint:#999;--border:rgba(0,0,0,0.08);--card:rgba(255,255,255,0.95);--input:#f0f0f0; }
        .theme-purple { --bg:#0d001a;--bg2:#15002e;--bg3:#1f0044;--red:#bb00ff;--red-dim:rgba(187,0,255,0.3);--text:#e8d0ff;--text-dim:#9a7abf;--text-faint:#5a3a7f;--border:rgba(187,0,255,0.1);--card:rgba(21,0,46,0.95);--input:#1a0030; }
        .theme-green { --bg:#001a0a;--bg2:#002e15;--bg3:#004420;--red:#00ff66;--red-dim:rgba(0,255,102,0.3);--text:#d0ffe0;--text-dim:#7abf9a;--text-faint:#3a7f5a;--border:rgba(0,255,102,0.1);--card:rgba(0,46,21,0.95);--input:#00301a; }
        .theme-gold { --bg:#1a1500;--bg2:#2e2500;--bg3:#443a00;--red:#ffd700;--red-dim:rgba(255,215,0,0.3);--text:#ffe8a0;--text-dim:#bfa060;--text-faint:#7f6a30;--border:rgba(255,215,0,0.1);--card:rgba(46,37,0,0.95);--input:#302800; }
        .theme-blue { --bg:#000a1a;--bg2:#00152e;--bg3:#002044;--red:#0099ff;--red-dim:rgba(0,153,255,0.3);--text:#d0e8ff;--text-dim:#7ab0bf;--text-faint:#3a607f;--border:rgba(0,153,255,0.1);--card:rgba(0,21,46,0.95);--input:#001830; }

        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            background:var(--bg); color:var(--text);
            font-family:'Rajdhani',sans-serif; min-height:100vh;
            transition:all 0.3s ease;
        }
        body::after { content:''; position:fixed; inset:0; pointer-events:none; z-index:9999; opacity:0.03;
            background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }

        /* Header */
        .header { position:fixed; top:0; left:0; right:0; z-index:100; background:rgba(10,10,15,0.9); backdrop-filter:blur(12px); border-bottom:1px solid var(--border); }
        .header-inner { max-width:1200px; margin:0 auto; padding:0 20px; height:60px; display:flex; align-items:center; gap:15px; }
        .logo { text-decoration:none; display:flex; align-items:baseline; gap:4px; }
        .logo-ix { font-family:'Cinzel',serif; font-size:1.3rem; font-weight:900; color:var(--red); }
        .logo-full { font-family:'Cinzel',serif; font-size:0.9rem; font-weight:700; color:var(--text-dim); letter-spacing:2px; }
        .nav { margin-left:auto; display:flex; align-items:center; gap:6px; }
        .nav a { color:var(--text-dim); text-decoration:none; font-weight:600; letter-spacing:1px; padding:6px 12px; font-size:13px; text-transform:uppercase; transition:color 0.2s; white-space:nowrap; }
        .nav a:hover { color:var(--text); }

        .more-menu { position:relative; display:inline-block; }
        .more-btn { background:none; border:none; color:var(--text-dim); font-size:20px; cursor:pointer; padding:6px 12px; letter-spacing:2px; }
        .more-btn:hover { color:var(--red); }
        .more-dropdown { position:absolute; top:42px; right:0; background:var(--card); border:1px solid var(--red-dim); border-radius:12px; min-width:180px; z-index:150; display:none; box-shadow:0 10px 40px rgba(0,0,0,0.6); overflow:hidden; }
        .more-dropdown.active { display:block; }
        .more-dropdown a { display:block; padding:12px 16px; color:var(--text-dim); text-decoration:none; font-size:13px; border-bottom:1px solid var(--border); }
        .more-dropdown a:hover { background:rgba(255,51,102,0.06); color:#fff; }

        .lang-switch { display:flex; gap:3px; }
        .lang-btn { background:transparent; border:1px solid #444; color:#888; padding:3px 8px; border-radius:5px; cursor:pointer; font-size:11px; font-weight:600; }
        .lang-btn.active { background:rgba(255,51,102,0.2); border-color:var(--red); color:var(--red); }

        /* Hero */
        .hero { padding:100px 20px 40px; text-align:center; }
        .hero h1 { font-family:'Cinzel',serif; font-size:clamp(2.5rem,6vw,4rem); font-weight:900; letter-spacing:3px; }
        .hero h1 span { background:linear-gradient(90deg,var(--red),var(--purple)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .hero p { color:var(--text-dim); font-size:1.1rem; margin:10px 0 20px; }

        .btn { padding:12px 28px; border-radius:10px; font-weight:700; letter-spacing:1px; cursor:pointer; font-family:'Rajdhani',sans-serif; text-decoration:none; display:inline-block; transition:all 0.2s; border:none; font-size:14px; text-transform:uppercase; }
        .btn-primary { background:linear-gradient(90deg,var(--red),var(--purple)); color:#fff; }
        .btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 25px rgba(255,51,102,0.3); }
        .btn-ghost { background:transparent; border:1px solid var(--border); color:var(--text-dim); }
        .btn-ghost:hover { border-color:var(--text); color:var(--text); }

        /* Секції */
        .section { max-width:1200px; margin:0 auto; padding:30px 20px; }
        .section-title { font-family:'Cinzel',serif; font-size:1.5rem; letter-spacing:2px; margin-bottom:20px; }

        /* ТОП художники */
        .top-artists { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:12px; margin-bottom:30px; }
        .top-artist { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:15px; text-align:center; cursor:pointer; transition:all 0.2s; }
        .top-artist:hover { transform:translateY(-3px); border-color:var(--red-dim); }
        .top-artist-avatar { width:50px; height:50px; border-radius:50%; background:var(--bg3); margin:0 auto 8px; display:flex; align-items:center; justify-content:center; font-weight:700; color:var(--red); overflow:hidden; border:2px solid var(--red-dim); }
        .top-artist-avatar img { width:100%; height:100%; object-fit:cover; }
        .top-artist-name { font-weight:600; font-size:13px; }
        .top-artist-likes { color:var(--red); font-size:12px; }

        /* Стрічка артів */
        .art-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:16px; }
        .art-card { background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:hidden; cursor:pointer; transition:all 0.2s; }
        .art-card:hover { transform:translateY(-4px); border-color:var(--red-dim); }
        .art-card img { width:100%; aspect-ratio:1; object-fit:cover; }
        .art-card-body { padding:10px 14px; }
        .art-card-title { font-weight:600; font-size:14px; }
        .art-card-author { color:var(--red); font-size:12px; cursor:pointer; }
        .art-card-author:hover { text-decoration:underline; }
        .art-card-meta { display:flex; justify-content:space-between; color:var(--text-faint); font-size:11px; margin-top:4px; }
        .bookmark-btn { background:none; border:none; cursor:pointer; font-size:16px; padding:2px 6px; }
        .bookmark-btn.saved { color:#ffd700; }
        .bookmark-btn:not(.saved) { color:var(--text-faint); }

        /* FAB */
        .fab { position:fixed; bottom:30px; right:30px; width:56px; height:56px; background:linear-gradient(135deg,var(--purple),var(--red)); border:none; border-radius:50%; color:#fff; font-size:26px; cursor:pointer; z-index:50; box-shadow:0 8px 30px var(--red-dim); transition:all 0.3s; display:none; }
        .fab:hover { transform:scale(1.1) rotate(90deg); }

        /* Профіль-модалка */
        .modal { position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:200; display:flex; align-items:center; justify-content:center; padding:20px; }
        .modal-content { background:var(--card); border:1px solid var(--red-dim); border-radius:20px; padding:30px; max-width:400px; width:100%; text-align:center; }
        .modal-avatar { width:80px; height:80px; border-radius:50%; border:3px solid var(--red); object-fit:cover; margin-bottom:12px; }

        /* Дзвіночок */
        .bell { position:relative; cursor:pointer; font-size:18px; color:var(--text-dim); padding:6px; }
        .bell-badge { position:absolute; top:0; right:0; background:var(--red); color:#fff; font-size:9px; width:16px; height:16px; border-radius:50%; display:none; align-items:center; justify-content:center; font-weight:700; }
        .bell-dropdown { position:absolute; top:38px; right:0; background:var(--card); border:1px solid var(--red-dim); border-radius:12px; width:300px; max-height:300px; overflow-y:auto; z-index:150; display:none; }
        .bell-dropdown.active { display:block; }
        .notif-item { padding:10px 14px; border-bottom:1px solid var(--border); font-size:12px; color:var(--text-dim); }
        .notif-item strong { color:var(--red); }

        @media(max-width:600px) {
            .nav a { font-size:11px; padding:4px 6px; }
            .art-grid { grid-template-columns:repeat(2,1fr); gap:10px; }
            .top-artists { grid-template-columns:repeat(3,1fr); }
        }
    </style>
</head>
<body>

<header class="header">
    <div class="header-inner">
        <a href="index.html" class="logo"><span class="logo-ix">IX</span><span class="logo-full">IZUNAX</span></a>
        <nav class="nav">
            <a href="gallery.html" data-uk="Галерея" data-en="Gallery">Галерея</a>
            <a href="chat.html">💬 <span data-uk="Чат" data-en="Chat">Чат</span></a>
            <a href="messages.html">✉ <span data-uk="ЛС" data-en="DM">ЛС</span></a>
            <a href="bookmarks.html">⭐ <span data-uk="Закладки" data-en="Saved">Закладки</span></a>
            <a href="profile.html" id="navProfile" style="display:none" data-uk="Профіль" data-en="Profile">Профіль</a>

            <span class="bell" id="bell" style="display:none" onclick="toggleBell()">
                🔔<span class="bell-badge" id="bellBadge">0</span>
                <div class="bell-dropdown" id="bellDropdown"></div>
            </span>

            <span class="lang-switch">
                <button class="lang-btn active" onclick="setLang('uk')">UA</button>
                <button class="lang-btn" onclick="setLang('en')">EN</button>
            </span>

            <span class="more-menu">
                <button class="more-btn" onclick="toggleMore()">⋯</button>
                <div class="more-dropdown" id="moreDropdown">
                    <a href="settings.html">⚙️ <span data-uk="Налаштування" data-en="Settings">Налаштування</span></a>
                    <a href="secret-admin.html">⚡ Admin</a>
                    <a href="#" onclick="doLogout()" style="color:#ff4444;">🚪 <span data-uk="Вийти" data-en="Logout">Вийти</span></a>
                </div>
            </span>

            <a href="login.html" id="navLogin" data-uk="Увійти" data-en="Login">Увійти</a>
            <a href="register.html" class="btn btn-primary" id="navReg" data-uk="Реєстрація" data-en="Register" style="font-size:12px;padding:8px 16px;">Реєстрація</a>
        </nav>
    </div>
</header>

<section class="hero">
    <h1><span data-uk="Твори. Без границь." data-en="Create. No limits.">Твори. Без границь.</span></h1>
    <p data-uk="Місце для аніме-артів, скетчів і всього з чорнил" data-en="A place for anime art, sketches and ink">Місце для аніме-артів, скетчів і всього з чорнил</p>
    <a href="register.html" class="btn btn-primary" data-uk="Почати" data-en="Start">Почати</a>
    <a href="gallery.html" class="btn btn-ghost" data-uk="Галерея" data-en="Gallery" style="margin-left:10px;">Галерея</a>
</section>

<div class="section">
    <h2 class="section-title">🔥 <span data-uk="ТОП автори" data-en="TOP Artists">ТОП автори</span></h2>
    <div class="top-artists" id="topArtists">Завантаження...</div>
</div>

<div class="section">
    <h2 class="section-title">📸 <span data-uk="Стрічка артів" data-en="Art Feed">Стрічка артів</span></h2>
    <div class="art-grid" id="artFeed">Завантаження...</div>
</div>

<button class="fab" id="fabBtn" onclick="publishArt()">+</button>

<script type="module"> 
import { auth, db, collection, getDocs, addDoc, query, orderBy, limit, doc, getDoc, updateDoc, arrayUnion, arrayRemove, serverTimestamp, onAuthStateChanged } from "./firebase-auth.js";

let currentUser = null;
let blockedUsers = [];
let bookmarks = [];
let allArts = [];
let currentLang = localStorage.getItem('izunax_lang') || 'uk';

// Тема
const savedTheme = localStorage.getItem('izunax_theme') || 'dark';
document.body.classList.toggle('theme-light', savedTheme === 'light');
document.body.classList.toggle('theme-purple', savedTheme === 'purple');
document.body.classList.toggle('theme-green', savedTheme === 'green');
document.body.classList.toggle('theme-gold', savedTheme === 'gold');
document.body.classList.toggle('theme-blue', savedTheme === 'blue');

// Мова
window.setLang = (lang) => {
    currentLang = lang;
    localStorage.setItem('izunax_lang', lang);
    document.querySelectorAll('.lang-btn').forEach(b => b.classList.toggle('active', b.textContent.trim().toLowerCase() === lang));
    document.querySelectorAll('[data-uk]').forEach(el => {
        if (!el.querySelector('span[data-uk]')) el.textContent = lang === 'en' ? el.dataset.en : el.dataset.uk;
    });
    document.querySelectorAll('span[data-uk]').forEach(el => el.textContent = lang === 'en' ? el.dataset.en : el.dataset.uk);
};
document.querySelector(`.lang-btn[onclick*="${currentLang}"]`)?.classList.add('active');

// Вихід
window.doLogout = () => { auth.signOut(); localStorage.removeItem('izunax_auth_persist'); window.location.href = 'login.html'; };

// Меню
window.toggleMore = () => document.getElementById('moreDropdown').classList.toggle('active');
document.addEventListener('click',e=>{if(!e.target.closest('.more-menu'))document.getElementById('moreDropdown').classList.remove('active');if(!e.target.closest('.bell'))document.getElementById('bellDropdown').classList.remove('active');});

// Авторизація
onAuthStateChanged(auth, async (user) => {
    if (user) {
        currentUser = user;
        document.getElementById('navLogin').style.display = 'none';
        document.getElementById('navReg').style.display = 'none';
        document.getElementById('navProfile').style.display = '';
        document.getElementById('bell').style.display = '';
        document.getElementById('fabBtn').style.display = 'flex';
        await loadBlocked();
        await loadBookmarks();
        await loadNotifications();
    } else {
        document.getElementById('fabBtn').style.display = 'none';
    }
    loadFeed();
    loadTopArtists();
    setLang(currentLang);
});

async function loadBlocked() {
    if (!currentUser) return;
    const snap = await getDoc(doc(db, 'users', currentUser.uid));
    blockedUsers = snap.exists() ? (snap.data().blockedUsers || []) : [];
}

async function loadBookmarks() {
    if (!currentUser) return;
    const snap = await getDoc(doc(db, 'users', currentUser.uid));
    bookmarks = snap.exists() ? (snap.data().bookmarks || []) : [];
}

// Стрічка
async function loadFeed() {
    const feed = document.getElementById('artFeed');
    try {
        const snap = await getDocs(query(collection(db, 'artworks'), orderBy('createdAt','desc'), limit(30)));
        allArts = []; snap.forEach(d => allArts.push({id:d.id,...d.data()}));
        const filtered = blockedUsers.length > 0 ? allArts.filter(a => !blockedUsers.includes(a.authorUid)) : allArts;
        if (filtered.length === 0) { feed.innerHTML = '<p style="color:var(--text-faint);grid-column:1/-1;text-align:center;padding:40px;">Немає артів</p>'; return; }
        feed.innerHTML = filtered.map(art => {
            const saved = bookmarks.includes(art.id);
            return `<div class="art-card" onclick="location.href='gallery.html'">
                <img src="${art.image}" alt="${art.title}" loading="lazy">
                <div class="art-card-body">
                    <div class="art-card-title">${art.title}</div>
                    <span class="art-card-author" onclick="event.stopPropagation();openUser('${art.authorUid}')">@${art.author}</span>
                    <div class="art-card-meta">
                        <span>♥ ${art.likes||0}</span>
                        <button class="bookmark-btn ${saved?'saved':''}" onclick="event.stopPropagation();toggleBookmark('${art.id}',${!saved})">${saved?'⭐':'☆'}</button>
                    </div>
                </div>
            </div>`;
        }).join('');
    } catch(e) { feed.innerHTML = `<p style="color:var(--red);">Помилка: ${e.message}</p>`; }
}

// ТОП
async function loadTopArtists() {
    const container = document.getElementById('topArtists');
    try {
        const snap = await getDocs(collection(db, 'users'));
        const users = []; snap.forEach(d => users.push(d.data()));
        const sorted = users.sort((a,b) => (b.likes||0) - (a.likes||0)).slice(0,8);
        container.innerHTML = sorted.map(u => `
            <div class="top-artist" onclick="openUser('${u.uid}')">
                <div class="top-artist-avatar">${u.avatar ? `<img src="${u.avatar}">` : (u.name||'?')[0]}</div>
                <div class="top-artist-name">${u.name||'Artist'}</div>
                <div class="top-artist-likes">♥ ${u.likes||0}</div>
            </div>
        `).join('');
    } catch(e) { container.innerHTML = '<p style="color:var(--text-faint);">—</p>'; }
}

// Закладки
window.toggleBookmark = async (artId, save) => {
    if (!currentUser) return alert('Увійди!');
    const ref = doc(db, 'users', currentUser.uid);
    await updateDoc(ref, save ? { bookmarks: arrayUnion(artId) } : { bookmarks: arrayRemove(artId) });
    bookmarks = save ? [...bookmarks, artId] : bookmarks.filter(id => id !== artId);
    loadFeed();
};

// Публікація
window.publishArt = () => {
    if (!currentUser) return alert('Увійди!');
    const inp = document.createElement('input'); inp.type='file'; inp.accept='image/*';
    inp.onchange = e => {
        const f = e.target.files[0]; if(!f) return; if(f.size>5*1024*1024)return alert('Max 5MB');
        const r = new FileReader();
        r.onload = async ev => {
            const title = prompt('Назва:');
            if(!title)return;
            await addDoc(collection(db,'artworks'),{
                title,image:ev.target.result,
                author:currentUser.displayName||'Artist',
                authorUid:currentUser.uid,
                desc:'',likes:0,createdAt:serverTimestamp()
            });
            loadFeed();
        };
        r.readAsDataURL(f);
    };
    inp.click();
};

// Профіль
window.openUser = async uid => {
    if(!uid)return;
    const m = document.createElement('div'); m.className='modal'; m.innerHTML='<div class="modal-content"><p>Loading...</p></div>';
    document.body.appendChild(m);
    const snap = await getDoc(doc(db,'users',uid));
    if(!snap.exists()){m.querySelector('.modal-content').innerHTML='<p>Not found</p>';return;}
    const u = snap.data(); const blocked = blockedUsers.includes(uid); const me = currentUser?.uid===uid;
    m.querySelector('.modal-content').innerHTML = `
        <img src="${u.avatar||'https://i.ibb.co/0jZqY7Z/default-avatar.png'}" class="modal-avatar">
        <h3 style="font-family:'Cinzel',
        serif;">${u.name||'Artist'} ${u.isVerified?'✓':''}</h3>
        <p style="color:var(--text-dim);">${u.bio||'—'}</p>
        <p>🎨${u.artworks||0} · ♥${u.likes||0}</p>
        ${u.isAdmin?'<span style="background:linear-gradient(90deg,#8b00ff,#ff1432);color:#fff;padding:3px 10px;border-radius:8px;">⚡Admin</span> ':''}
        ${u.isCreator?'<span style="background:linear-gradient(90deg,#ffd700,#ff8c00);color:#000;padding:3px 10px;border-radius:8px;">★Creator</span>':''}
        ${!me?`<div style="margin-top:12px;">
            <button onclick="toggleBlock('${uid}',${!blocked})" style="padding:6px 16px;border-radius:16px;cursor:pointer;${blocked?'background:transparent;border:1px solid #4caf50;color:#4caf50;':'background:#ff4444;border:none;color:#fff;'}">${blocked?'✅ Unblock':'🚫 Block'}</button>
            <button onclick="location.href='messages.html?uid=${uid}'" style="margin-left:5px;padding:6px 16px;border-radius:16px;cursor:pointer;background:linear-gradient(90deg,#8b00ff,#ff1432);border:none;color:#fff;">💬 Написати</button>
        </div>`:''}
        <button onclick="this.closest('.modal').remove()" style="margin-top:10px;padding:6px 20px;background:var(--bg3);border:none;border-radius:8px;color:var(--text-dim);cursor:pointer;">Закрити</button>`;
    m.addEventListener('click',e=>{if(e.target===m)m.remove();});
};

window.toggleBlock = async (uid, block) => {
    if(!currentUser)return;
    const ref = doc(db,'users',currentUser.uid);
    await updateDoc(ref, block ? {blockedUsers:arrayUnion(uid)} : {blockedUsers:arrayRemove(uid)});
    blockedUsers = block ? [...blockedUsers, uid] : blockedUsers.filter(id=>id!==uid);
    document.querySelector('.modal')?.remove();
    loadFeed();
};

// Сповіщення
async function loadNotifications() {
    if(!currentUser)return;
    const snap = await getDocs(query(collection(db,'notifications'),orderBy('createdAt','desc'),limit(15)));
    const n=[]; snap.forEach(d=>{if(d.data().forUid===currentUser.uid)n.push(d.data());});
    const badge = document.getElementById('bellBadge');
    const unread = n.filter(x=>!x.read).length;
    badge.textContent = unread||''; badge.style.display = unread>0?'flex':'none';
    document.getElementById('bellDropdown').innerHTML = n.length===0
        ?'<div class="notif-item" style="text-align:center;">Немає сповіщень</div>'
        :n.map(x=>`<div class="notif-item"><strong>${x.fromName||'Хтось'}</strong> ${x.type==='like'?'❤':x.type==='comment'?'💬':''}<br><small>${x.createdAt?.seconds?new Date(x.createdAt.seconds*1000).toLocaleString():''}</small></div>`).join('');
}
window.toggleBell = () => { document.getElementById('bellDropdown').classList.toggle('active'); loadNotifications(); };

setLang(currentLang);
// Запуск AI ботів
if (!window._botStarted) {
    window._botStarted = true;
    import("./ai-bot.js").then(module => {
        module.startAIBot(db, collection, addDoc, getDocs, updateDoc, doc, increment, serverTimestamp);
    });
}
</script>
</body>
</html>